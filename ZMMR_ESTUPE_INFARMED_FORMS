ENDFORM.

*---------------------------------------------------------------------*
* FILTER_SEL_BY_DOC - Determina documento selecionado no ALV
*---------------------------------------------------------------------*
FORM FILTER_SEL_BY_DOC USING IO_GRID TYPE REF TO CL_GUI_ALV_GRID
CHANGING CS_DOC  TYPE TY_DOCID.

  DATA LT_ROWS TYPE LVC_T_ROW.
  DATA LS_ROW  TYPE LVC_S_ROW.

  CLEAR CS_DOC.

  IF IO_GRID IS INITIAL.
    RETURN.
  ENDIF.

  CALL METHOD IO_GRID->GET_SELECTED_ROWS
    IMPORTING
      ET_INDEX_ROWS = LT_ROWS.

  READ TABLE LT_ROWS INTO LS_ROW INDEX 1.
  IF SY-SUBRC <> 0.
    RETURN.
  ENDIF.

  READ TABLE GT_OUT ASSIGNING FIELD-SYMBOL(<O>) INDEX LS_ROW-INDEX.
  IF SY-SUBRC <> 0.
    RETURN.
  ENDIF.

  CS_DOC-MBLNR = <O>-MBLNR.
  CS_DOC-MJAHR = <O>-MJAHR.

ENDFORM.


*---------------------------------------------------------------------*
* WRITE_LIST_FOR_PDF - Escreve o conteúdo como LIST (para spool)
*---------------------------------------------------------------------*
FORM WRITE_LIST_FOR_PDF USING IT_OUT TYPE STANDARD TABLE.

  FIELD-SYMBOLS <O> TYPE TY_OUT.

  "Cabeçalho
  WRITE: / 'Listagem Obrigatória para artigos Estupefacientes (INFARMED)'.
  WRITE: / 'Ano:', P_ANO, '  Data geraçăo:', SY-DATUM.
  ULINE.

  "Colunas (ajuste como quiser)
  FORMAT COLOR COL_HEADING INTENSIFIED ON.
  WRITE: / 'Data', 12 'Registo', 50 'Documento', 90 'Artigo', 110 'Tipo', 118 'Qtd', 132 'Un', 138 'Stock'.
  FORMAT RESET.
  ULINE.

  LOOP AT IT_OUT ASSIGNING <O>.
    WRITE: / <O>-BUDAT,
    12 <O>-REGISTO,
    50 <O>-DOCUMENTO,
    90 <O>-MATNR,
    110 <O>-TIPO,
    118 <O>-MENGE,
    132 <O>-MEINS,
    138 <O>-STOCK.
  ENDLOOP.

ENDFORM.



FORM GET_ALV_SELECTION
USING    IO_GRID TYPE REF TO CL_GUI_ALV_GRID
CHANGING CT_SEL  TYPE STANDARD TABLE.

  DATA: LT_ROWS TYPE LVC_T_ROW,
        LS_ROW  TYPE LVC_S_ROW.

  FIELD-SYMBOLS: <WA> TYPE TY_OUT.

  CLEAR CT_SEL.
  CLEAR LT_ROWS.

  IF IO_GRID IS INITIAL.
    RETURN.
  ENDIF.

  CALL METHOD IO_GRID->GET_SELECTED_ROWS
    IMPORTING
      ET_INDEX_ROWS = LT_ROWS.

  IF LT_ROWS IS INITIAL.
    "Sem seleçăo -> pega tudo que está no ALV
    LOOP AT GT_OUT ASSIGNING <WA>.
      APPEND <WA> TO CT_SEL.
    ENDLOOP.
    RETURN.
  ENDIF.

  LOOP AT LT_ROWS INTO LS_ROW.
    READ TABLE GT_OUT ASSIGNING <WA> INDEX LS_ROW-INDEX.
    IF SY-SUBRC = 0.
      APPEND <WA> TO CT_SEL.
    ENDIF.
  ENDLOOP.
ENDFORM.


FORM BUILD_FCAT_FALLBACK CHANGING CT_FCAT TYPE LVC_T_FCAT.

  DATA LS TYPE LVC_S_FCAT.

  CLEAR CT_FCAT.

  CLEAR LS. LS-FIELDNAME = 'BUDAT'.     LS-COLTEXT = 'Data'.           LS-OUTPUTLEN = 10. APPEND LS TO CT_FCAT.
  CLEAR LS. LS-FIELDNAME = 'REGISTO'.   LS-COLTEXT = 'Registo'.        LS-OUTPUTLEN = 20. APPEND LS TO CT_FCAT.
  CLEAR LS. LS-FIELDNAME = 'DOCUMENTO'. LS-COLTEXT = 'Documento'.      LS-OUTPUTLEN = 25. APPEND LS TO CT_FCAT.
  CLEAR LS. LS-FIELDNAME = 'MATNR'.     LS-COLTEXT = 'Cod. Artigo'.    LS-OUTPUTLEN = 18. APPEND LS TO CT_FCAT.
  CLEAR LS. LS-FIELDNAME = 'MAKTX'.     LS-COLTEXT = 'Substância Ativa'. LS-OUTPUTLEN = 40. APPEND LS TO CT_FCAT.
  CLEAR LS. LS-FIELDNAME = 'TIPO'.      LS-COLTEXT = 'Tipo'.           LS-OUTPUTLEN = 4.  APPEND LS TO CT_FCAT.
  CLEAR LS. LS-FIELDNAME = 'MENGE'.     LS-COLTEXT = 'Quant.'.         LS-OUTPUTLEN = 13. LS-JUST = 'R'. APPEND LS TO CT_FCAT.
  CLEAR LS. LS-FIELDNAME = 'MEINS'.     LS-COLTEXT = 'Unid.'.          LS-OUTPUTLEN = 5.  APPEND LS TO CT_FCAT.
  CLEAR LS. LS-FIELDNAME = 'STOCK'.     LS-COLTEXT = 'Stock'.          LS-OUTPUTLEN = 13. LS-JUST = 'R'. APPEND LS TO CT_FCAT.
  CLEAR LS. LS-FIELDNAME = 'WERKS'.     LS-COLTEXT = 'Centro'.         LS-OUTPUTLEN = 6.  APPEND LS TO CT_FCAT.
  CLEAR LS. LS-FIELDNAME = 'LGORT'.     LS-COLTEXT = 'Depósito'.       LS-OUTPUTLEN = 6.  APPEND LS TO CT_FCAT.
  CLEAR LS. LS-FIELDNAME = 'SERV_FORN'. LS-COLTEXT = 'Serv./Forn.'.    LS-OUTPUTLEN = 25. APPEND LS TO CT_FCAT.
  CLEAR LS. LS-FIELDNAME = 'DESCR'.     LS-COLTEXT = 'Descriçăo'.      LS-OUTPUTLEN = 40. APPEND LS TO CT_FCAT.
  CLEAR LS. LS-FIELDNAME = 'CONSU'.     LS-COLTEXT = 'Consumo'.LS-OUTPUTLEN = 30. APPEND LS TO CT_FCAT.

ENDFORM.

FORM PARSE_REGISTO USING    IV_REG   TYPE STRING
CHANGING CV_PO    TYPE EBELN
  CV_PR    TYPE BANFN
  CV_MBLNR TYPE MBLNR.

  DATA: LV TYPE STRING,
        LT TYPE STANDARD TABLE OF STRING WITH DEFAULT KEY,
        WA TYPE STRING.

  CLEAR: CV_PO, CV_PR, CV_MBLNR.

  LV = IV_REG.

  "Separar por espaço e '/'
  REPLACE ALL OCCURRENCES OF '/' IN LV WITH SPACE.
  CONDENSE LV.

  SPLIT LV AT SPACE INTO TABLE LT.

  LOOP AT LT INTO WA.
    "PO normalmente 10 dígitos
    IF WA CO '0123456789' AND STRLEN( WA ) = 10 AND CV_PO IS INITIAL.
      CV_PO = WA.
      CONTINUE.
    ENDIF.

    "PR BANFN normalmente 10 dígitos também (depende do customizing)
    IF WA CO '0123456789' AND STRLEN( WA ) = 10 AND CV_PR IS INITIAL.
      "se já achou PO, năo confunde
      IF CV_PO IS INITIAL.
        CV_PR = WA.
      ENDIF.
      CONTINUE.
    ENDIF.

    "Doc material MBLNR é 10 dígitos (muito comum)
    IF WA CO '0123456789' AND STRLEN( WA ) = 10 AND CV_MBLNR IS INITIAL.
      CV_MBLNR = WA.
      CONTINUE.
    ENDIF.
  ENDLOOP.

ENDFORM.

*---------------------------------------------------------------------*
* INFARMED - Entrypoint do botăo no ALV (Gerar INFARMED)
*---------------------------------------------------------------------*
FORM INFARMED_POPUP_AND_RUN USING IO_GRID TYPE REF TO CL_GUI_ALV_GRID.

  DATA: LT_ITEMS   TYPE ZTTSESTUPE_ITEM,
        LS_HEADER  TYPE ZSESTUPE_HDR,
        LV_CHOICE  TYPE C LENGTH 1,
        LV_PDF     TYPE XSTRING,
        LV_DT_INI  TYPE D,
        LV_DT_TERM TYPE D.

  CLEAR: LT_ITEMS, LS_HEADER, LV_CHOICE, LV_PDF, LV_DT_INI, LV_DT_TERM.

  "1) Pegar linhas selecionadas (ou tudo se nada selecionado) + montar IT_ITEMS
  PERFORM INFARMED_GET_SELECTED_OUT USING IO_GRID
  CHANGING LT_ITEMS.

  IF LT_ITEMS IS INITIAL.
    MESSAGE 'Sem dados para gerar INFARMED.' TYPE 'I'.
    RETURN.
  ENDIF.

  "2) Montar Header/Datas (ajuste aqui se quiser puxar do selection-screen)
  PERFORM INFARMED_BUILD_HEADER CHANGING LS_HEADER LV_DT_INI LV_DT_TERM.

  "3) Popup: 1=SPOOL / 2=PDF
  PERFORM INFARMED_ASK_OUTPUT CHANGING LV_CHOICE.
  IF LV_CHOICE IS INITIAL.
    RETURN. "cancel
  ENDIF.

  CASE LV_CHOICE.
    WHEN '1'. "SPOOL com diálogo padrăo
      PERFORM CALL_SMARTFORM_SPOOL USING LT_ITEMS LS_HEADER LV_DT_INI LV_DT_TERM.

    WHEN '2'. "PDF (OTF->PDF) e download/abrir
      PERFORM GENERATE_PDF_SMARTFORM USING LT_ITEMS LS_HEADER LV_DT_INI LV_DT_TERM
      CHANGING LV_PDF.

      IF LV_PDF IS INITIAL.
        MESSAGE 'Falha ao gerar PDF do Smartform.' TYPE 'E'.
        RETURN.
      ENDIF.

      PERFORM PDF_DOWNLOAD_AND_OPEN USING LV_PDF.
  ENDCASE.

ENDFORM.

*---------------------------------------------------------------------*
* INFARMED_GET_SELECTED_OUT
* - Lę seleçăo do ALV (ou tudo se nada selecionado)
* - Converte GT_OUT (TY_OUT) -> ZTTSESTUPE_ITEM (ZSESTUPE_ITEM)
*---------------------------------------------------------------------*
FORM INFARMED_GET_SELECTED_OUT USING IO_GRID TYPE REF TO CL_GUI_ALV_GRID
CHANGING CT_ITEMS TYPE ZTTSESTUPE_ITEM.

  DATA: LT_ROWS TYPE LVC_T_ROW,
        LS_ROW  TYPE LVC_S_ROW,
        LT_OUT  TYPE STANDARD TABLE OF TY_OUT,
        LS_OUT  TYPE TY_OUT.

  CLEAR: CT_ITEMS, LT_ROWS, LT_OUT.

  "1) Pegar linhas selecionadas no GRID
  IF IO_GRID IS BOUND.
    CALL METHOD IO_GRID->GET_SELECTED_ROWS
      IMPORTING
        ET_INDEX_ROWS = LT_ROWS.
  ENDIF.

  "2) Obrigatório selecionar pelo menos 1 linha
  IF LT_ROWS IS INITIAL.
    MESSAGE 'Selecione ao menos uma linha para gerar o INFARMED.' TYPE 'I'.
    RETURN.
  ENDIF.

  "3) Montar LT_OUT apenas com as linhas selecionadas
  LOOP AT LT_ROWS INTO LS_ROW.
    READ TABLE GT_OUT INTO LS_OUT INDEX LS_ROW-INDEX.
    IF SY-SUBRC = 0.
      APPEND LS_OUT TO LT_OUT.
    ENDIF.
  ENDLOOP.

  IF LT_OUT IS INITIAL.
    MESSAGE 'Seleçăo inválida. Tente selecionar novamente.' TYPE 'I'.
    RETURN.
  ENDIF.

  "4) Converter para o tipo do Smartform (ZTTSESTUPE_ITEM)
  PERFORM BUILD_INFARMED_DATA USING LT_OUT
  CHANGING CT_ITEMS.

ENDFORM.

FORM INFARMED_ASK_OUTPUT CHANGING CV_CHOICE TYPE C.

  DATA: LT_LIST TYPE STANDARD TABLE OF SPOPLI,
        LS_LIST TYPE SPOPLI.

  DATA LV_ANS TYPE C.

  CLEAR: LT_LIST, LS_LIST.

  LS_LIST-SELFLAG = 'X'.
  LS_LIST-VAROPTION  = 'Gerar via SPOOL (com diálogo de impressăo)'.
  APPEND LS_LIST TO LT_LIST.

  CLEAR LS_LIST.
  LS_LIST-SELFLAG = ' '.
  LS_LIST-VAROPTION  = 'Visualizar PDF (gerar PDF do Smartform)'.
  APPEND LS_LIST TO LT_LIST.

  CALL FUNCTION 'POPUP_TO_DECIDE_LIST'
    EXPORTING
      TEXTLINE1 = 'INFARMED'
      TEXTLINE2 = 'Escolha o modo de geraçăo'
      TITEL     = 'Gerar INFARMED'
    IMPORTING
      ANSWER    = LV_ANS
    TABLES
      T_SPOPLI  = LT_LIST.

  "answer = 'A' se escolheu algo; dependendo do sistema pode variar.
  "Vamos ler o retorno via SY-TABIX năo vem; entăo tratamos simples:
  "Se cancel -> lv_ans vazio
  IF LV_ANS IS INITIAL.
    CLEAR CV_CHOICE.
    RETURN.
  ENDIF.

  "Alguns sistemas retornam em lv_ans o VAROPTION escolhido:
  "Se no seu năo retornar, trocamos para POPUP_GET_VALUES depois.
  CV_CHOICE = LV_ANS.

ENDFORM.

*---------------------------------------------------------------------*
* CALL_SMARTFORM_SPOOL
* - Abre o diálogo padrăo de spool (USER_SETTINGS = 'X')
*---------------------------------------------------------------------*
FORM CALL_SMARTFORM_SPOOL USING IT_ITEMS  TYPE ZTTSESTUPE_ITEM
      IS_HEADER TYPE ZSESTUPE_HDR
      IV_DT_INI TYPE D
      IV_DT_TERM TYPE D.

  DATA: LV_FM_NAME TYPE RS38L_FNAM,
        LS_CTRL    TYPE SSFCTRLOP,
        LS_COMP    TYPE SSFCOMPOP.

  "1) Resolver FM do Smartform
  CALL FUNCTION 'SSF_FUNCTION_MODULE_NAME'
    EXPORTING
      FORMNAME           = C_SMARTFORM_NAME
    IMPORTING
      FM_NAME            = LV_FM_NAME
    EXCEPTIONS
      NO_FORM            = 1
      NO_FUNCTION_MODULE = 2
      OTHERS             = 3.

  IF SY-SUBRC <> 0 OR LV_FM_NAME IS INITIAL.
    MESSAGE 'Smartform năo encontrado ou sem FM gerada.' TYPE 'E'.
    RETURN.
  ENDIF.

  "2) Forçar diálogo de spool
  CLEAR: LS_CTRL, LS_COMP.
  LS_CTRL-NO_DIALOG = SPACE.   "tem diálogo
  LS_CTRL-PREVIEW   = SPACE.
  LS_CTRL-DEVICE    = 'PRINTER'.

  "3) USER_SETTINGS='X' => abre a janela padrăo de impressăo
  CALL FUNCTION LV_FM_NAME
    EXPORTING
      CONTROL_PARAMETERS = LS_CTRL
      OUTPUT_OPTIONS     = LS_COMP
      USER_SETTINGS      = 'X'
      IS_HEADER          = IS_HEADER
      IV_DT_INI          = IV_DT_INI
      IV_DT_TERM         = IV_DT_TERM
      IT_ITENS           = IT_ITEMS
    EXCEPTIONS
      FORMATTING_ERROR   = 1
      INTERNAL_ERROR     = 2
      SEND_ERROR         = 3
      USER_CANCELED      = 4
      OTHERS             = 5.

  IF SY-SUBRC <> 0 AND SY-SUBRC <> 4.
    MESSAGE 'Erro ao chamar Smartform (SPOOL).' TYPE 'E'.
  ENDIF.

ENDFORM.

*---------------------------------------------------------------------*
* PDF_DOWNLOAD_AND_OPEN
* - Salva no frontend: INFARMED_<timestamp>.pdf
* - E abre o ficheiro automaticamente
*---------------------------------------------------------------------*
*---------------------------------------------------------------------*
*  Download + abrir PDF (nome: INFARMED_<timestamp>.pdf)
*---------------------------------------------------------------------*
FORM PDF_DOWNLOAD_AND_OPEN USING IV_PDF TYPE XSTRING.

  DATA: LV_FILENAME TYPE STRING,
        LV_PATH     TYPE STRING,
        LV_FULLPATH TYPE STRING,
        LV_TS       TYPE TIMESTAMPL,
        LV_STAMP    TYPE STRING,
        LT_BIN      TYPE SOLIX_TAB,
        LV_LEN      TYPE I.

  IF IV_PDF IS INITIAL.
    RETURN.
  ENDIF.

  "Timestamp seguro (corrige teu dump REPLACE_INFINITE_LOOP)
  GET TIME STAMP FIELD LV_TS.
  LV_STAMP = LV_TS.
  "remove tudo que năo for número
  REPLACE ALL OCCURRENCES OF REGEX '[^0-9]' IN LV_STAMP WITH ''.

  CONCATENATE 'INFARMED_' LV_STAMP '.pdf' INTO LV_FILENAME.

  CALL METHOD CL_GUI_FRONTEND_SERVICES=>FILE_SAVE_DIALOG
    EXPORTING
      DEFAULT_EXTENSION = 'pdf'
      DEFAULT_FILE_NAME = LV_FILENAME
    CHANGING
      FILENAME          = LV_FILENAME
      PATH              = LV_PATH
      FULLPATH          = LV_FULLPATH
    EXCEPTIONS
      OTHERS            = 1.

  IF SY-SUBRC <> 0 OR LV_FULLPATH IS INITIAL.
    RETURN.
  ENDIF.

  CALL FUNCTION 'SCMS_XSTRING_TO_BINARY'
    EXPORTING
      BUFFER        = IV_PDF
    IMPORTING
      OUTPUT_LENGTH = LV_LEN
    TABLES
      BINARY_TAB    = LT_BIN
    EXCEPTIONS
      FAILED        = 1
      OTHERS        = 2.

  IF SY-SUBRC <> 0.
    RETURN.
  ENDIF.

  CALL METHOD CL_GUI_FRONTEND_SERVICES=>GUI_DOWNLOAD
    EXPORTING
      FILENAME     = LV_FULLPATH
      FILETYPE     = 'BIN'
      BIN_FILESIZE = LV_LEN
    CHANGING
      DATA_TAB     = LT_BIN
    EXCEPTIONS
      OTHERS       = 1.

  IF SY-SUBRC <> 0.
    RETURN.
  ENDIF.

  "Abrir automaticamente
  CALL METHOD CL_GUI_FRONTEND_SERVICES=>EXECUTE
    EXPORTING
      DOCUMENT = LV_FULLPATH
    EXCEPTIONS
      OTHERS   = 1.

ENDFORM.

*---------------------------------------------------------------------*
* BUILD_INFARMED_DATA
* Converte LT_OUT (TY_OUT) -> CT_ITEMS (ZTTSESTUPE_ITEM)
*---------------------------------------------------------------------*
FORM BUILD_INFARMED_DATA USING    IT_OUT   TYPE STANDARD TABLE
CHANGING CT_ITEMS TYPE ZTTSESTUPE_ITEM.

  DATA: LS_OUT  TYPE TY_OUT,
        LS_ITEM TYPE ZSESTUPE_ITEM.

  CLEAR CT_ITEMS.

  LOOP AT IT_OUT INTO LS_OUT.
    CLEAR LS_ITEM.

    "Mapeamento direto (ajuste campos se necessário)
    LS_ITEM-BUDAT     = LS_OUT-BUDAT.
    LS_ITEM-REGISTO   = LS_OUT-REGISTO.
    LS_ITEM-DOCUMENTO = LS_OUT-DOCUMENTO.
    LS_ITEM-MATNR     = LS_OUT-MATNR.
    LS_ITEM-MAKTX     = LS_OUT-MAKTX.
    LS_ITEM-TIPO      = LS_OUT-TIPO.
    LS_ITEM-MENGE     = LS_OUT-MENGE.
    LS_ITEM-MEINS     = LS_OUT-MEINS.
    LS_ITEM-STOCK     = LS_OUT-STOCK.
    LS_ITEM-LOTE      = LS_OUT-LOTE.
    LS_ITEM-SERV_FORN = LS_OUT-SERV_FORN.
    LS_ITEM-DESCR     = LS_OUT-DESCR.

    APPEND LS_ITEM TO CT_ITEMS.
  ENDLOOP.
ENDFORM.

