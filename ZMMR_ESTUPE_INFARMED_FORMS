*&---------------------------------------------------------------------*
*& Include          ZMMR_ESTUPE_INFARMED_FORMS
*&---------------------------------------------------------------------*
*& Objetivo:
*&  - Construir e exibir ALV (CL_GUI_ALV_GRID)
*&  - Gerar PDF por Documento Material (MBLNR/MJAHR) via Spool->PDF
*&---------------------------------------------------------------------*

*---------------------------------------------------------------------*
* GET_DATA - Lę movimentos do ano e monta GT_OUT
*---------------------------------------------------------------------*
FORM GET_DATA .

  DATA: LT_BASE TYPE TT_BASE,
        LT_MAKT TYPE TABLE OF MAKT,
        LT_EKPO TYPE TABLE OF EKPO,
        LT_CSKT TYPE TABLE OF CSKT.

  CONCATENATE P_ANO '0101' INTO GV_DATE_FROM.
  CONCATENATE P_ANO '1231' INTO GV_DATE_TO.

  "Base: movimentos 101/201/301 no ano (MKPF+MSEG)
  CLEAR LT_BASE.
  SELECT K~BUDAT
         M~MBLNR
         M~MJAHR
         M~ZEILE
         M~MATNR
         M~WERKS
         M~LGORT
         M~BWART
         M~MENGE
         M~MEINS
         M~SGTXT
         M~EBELN
         M~EBELP
         M~KOSTL
         M~CHARG
         M~LIFNR
  FROM MSEG AS M
  INNER JOIN MKPF AS K
  ON K~MBLNR = M~MBLNR
  AND K~MJAHR = M~MJAHR
  INTO TABLE LT_BASE
  WHERE K~BUDAT BETWEEN GV_DATE_FROM AND GV_DATE_TO
  AND   M~MATNR IN S_MATNR
  AND   M~BWART IN R_BWART
  AND   M~XAUTO EQ ' '.

  IF LT_BASE IS INITIAL.
    CLEAR GT_OUT.
    RETURN.
  ENDIF.

  "MAKT (texto material)
  CLEAR LT_MAKT.
  SELECT *
  FROM MAKT
  INTO TABLE LT_MAKT
  FOR ALL ENTRIES IN LT_BASE
  WHERE MATNR = LT_BASE-MATNR
  AND SPRAS = SY-LANGU.
  SORT LT_MAKT BY MATNR.

  "EKPO (BANFN)
  CLEAR LT_EKPO.
  SELECT *
  FROM EKPO
  INTO TABLE LT_EKPO
  FOR ALL ENTRIES IN LT_BASE
  WHERE EBELN = LT_BASE-EBELN
  AND EBELP = LT_BASE-EBELP.
  SORT LT_EKPO BY EBELN EBELP.

  "Fornecedor por PO (EKKO -> LFA1)
  CLEAR GT_VENDOR[].
  SELECT M~MBLNR L~LIFNR L~NAME1
  FROM MSEG AS M INNER JOIN LFA1 AS L
  ON L~LIFNR = M~LIFNR
  INTO TABLE GT_VENDOR
  FOR ALL ENTRIES IN LT_BASE
  WHERE MBLNR EQ LT_BASE-MBLNR
  AND   MJAHR EQ LT_BASE-MJAHR.
  SORT GT_VENDOR BY MBLNR.
*  SELECT E~EBELN L~LIFNR L~NAME1
*  FROM EKKO AS E
*  INNER JOIN LFA1 AS L
*  ON L~LIFNR = E~LIFNR
*  INTO TABLE LT_VENDOR
*  FOR ALL ENTRIES IN LT_BASE
*  WHERE E~EBELN = LT_BASE-EBELN.
*  SORT LT_VENDOR BY EBELN.

  "Serviço por Centro de Custo (CSKT)
  CLEAR LT_CSKT.
  SELECT *
  FROM CSKT
  INTO TABLE LT_CSKT
  FOR ALL ENTRIES IN LT_BASE
  WHERE KOSTL = LT_BASE-KOSTL
  AND SPRAS = SY-LANGU
  AND DATBI >= SY-DATUM.
  SORT LT_CSKT BY KOSTL.

  "Montar GT_OUT
  CLEAR GT_OUT.
  LOOP AT LT_BASE ASSIGNING FIELD-SYMBOL(<B>).

    DATA LS_OUT TYPE TY_OUT.
    CLEAR LS_OUT.

    LS_OUT-BUDAT = <B>-BUDAT.
    LS_OUT-MBLNR = <B>-MBLNR.
    LS_OUT-MJAHR = <B>-MJAHR.
    LS_OUT-ZEILE = <B>-ZEILE.
    LS_OUT-MATNR = <B>-MATNR.
    LS_OUT-LOTE  = <B>-CHARG.
    LS_OUT-LGORT = <B>-LGORT.
    LS_OUT-BWART = <B>-BWART.
    LS_OUT-MEINS = <B>-MEINS.
    LS_OUT-CONSU = <B>-SGTXT.
    LS_OUT-EBELN = <B>-EBELN.
    LS_OUT-MENGE = <B>-MENGE.
    LS_OUT-EBELP = <B>-EBELP.
    LS_OUT-KOSTL = <B>-KOSTL.
    LS_OUT-WERKS = <B>-WERKS.

    "Tipo EN/SD/TR (regra simples)
    IF LS_OUT-BWART IN R_BWART_EN. "ENtrada
      "BANFN
*      IF LS_OUT-EBELN IS NOT INITIAL.
*        READ TABLE LT_EKPO ASSIGNING FIELD-SYMBOL(<P>)
*        WITH KEY EBELN = LS_OUT-EBELN EBELP = LS_OUT-EBELP BINARY SEARCH.
*        IF SY-SUBRC = 0.
*          LS_OUT-BANFN = <P>-BANFN.
*        ENDIF.
*      ENDIF.
      LS_OUT-TIPO = 'EN'.
      LS_OUT-REGISTO = <B>-EBELN.
    ENDIF.

    IF LS_OUT-BWART IN R_BWART_SD.  "Saida
      LS_OUT-TIPO = 'SD'.
      LS_OUT-REGISTO = <B>-MBLNR.
      LS_OUT-MENGE = - ABS( LS_OUT-MENGE ).
    ENDIF.

    IF LS_OUT-BWART IN R_BWART_TR. "Transfer
      LS_OUT-TIPO = 'TR'.
      LS_OUT-REGISTO = <B>-MBLNR.
      LS_OUT-MENGE = - ABS( LS_OUT-MENGE ).
    ENDIF.

    "Texto material (substância activa)
    READ TABLE LT_MAKT ASSIGNING FIELD-SYMBOL(<T>)
    WITH KEY MATNR = LS_OUT-MATNR BINARY SEARCH.
    IF SY-SUBRC = 0.
      LS_OUT-MAKTX = <T>-MAKTX.
    ENDIF.
    "REGISTO: Req/PO/Doc
    "    CONCATENATE 'Req' LS_OUT-BANFN '/' 'PO' LS_OUT-EBELN '/' 'Doc' LS_OUT-MBLNR
    "    INTO LS_OUT-REGISTO SEPARATED BY SPACE.

    "DOCUMENTO: texto
    "    IF LS_OUT-TIPO = 'SD' AND LS_OUT-SGTXT IS NOT INITIAL.
    "      CONCATENATE 'Consumo ao doente -' LS_OUT-SGTXT INTO LS_OUT-DOCUMENTO SEPARATED BY SPACE.
    "    ELSE.
    LS_OUT-DOCUMENTO = <B>-MBLNR.
    "    ENDIF.

    "SERV/FORN
    IF LS_OUT-TIPO = 'EN' .
      READ TABLE GT_VENDOR ASSIGNING FIELD-SYMBOL(<V>)
      WITH KEY MBLNR = LS_OUT-MBLNR BINARY SEARCH.
      IF SY-SUBRC = 0.
        CALL FUNCTION 'CONVERSION_EXIT_ALPHA_OUTPUT'
          EXPORTING
            INPUT  = <V>-LIFNR
          IMPORTING
            OUTPUT = LS_OUT-SERV_FORN.
        LS_OUT-DESCR     = <V>-NAME1.
      ENDIF.
    ENDIF.

    IF LS_OUT-TIPO = 'SD' AND LS_OUT-KOSTL IS NOT INITIAL.
      READ TABLE LT_CSKT ASSIGNING FIELD-SYMBOL(<C>)
     WITH KEY KOSTL = LS_OUT-KOSTL BINARY SEARCH.
      IF SY-SUBRC = 0.
        LS_OUT-SERV_FORN =  <B>-KOSTL.
        LS_OUT-DESCR     = <C>-LTEXT.
      ENDIF.
    ENDIF.

    APPEND LS_OUT TO GT_OUT.
  ENDLOOP.

  SORT GT_OUT BY BUDAT MBLNR ZEILE.
ENDFORM.

*---------------------------------------------------------------------*
* CALC_STOCK
* - Stock por Material/Centro/Depósito (sem lote)
* - Lę MARD-LABST com chave MATNR + WERKS + LGORT
* - Move para GT_OUT-STOCK
*---------------------------------------------------------------------*
FORM CALC_STOCK .

  DATA: LV_FREE TYPE LABST,
        LV_QI   TYPE LABST,
        LV_BLK  TYPE LABST,
        LV_TRF  TYPE LABST,
        LV_GRB  TYPE LABST,
        LV_VFD  TYPE VFDAT,
        LS_RET  TYPE BAPIRET2_TAB.

  FIELD-SYMBOLS: <O> TYPE TY_OUT.

  LOOP AT GT_OUT ASSIGNING <O>.
    IF <O>-TIPO = 'EN' .
      READ TABLE GT_VENDOR ASSIGNING FIELD-SYMBOL(<V>)
      WITH KEY MBLNR = <O>-MBLNR BINARY SEARCH.
      IF SY-SUBRC EQ 0.
        DATA(LV_LIFNR) = <V>-LIFNR.
      ENDIF.
    ENDIF.
    CALL FUNCTION 'ZFM_GET_MMBE_QTY'
      EXPORTING
        IV_MATNR  = <O>-MATNR
        IV_WERKS  = <O>-WERKS
        IV_LGORT  = <O>-LGORT
        IV_CHARG  = <O>-LOTE
        IV_LIFNR  = LV_LIFNR
      IMPORTING
        EV_QTY    = LV_FREE
        ET_RETURN = LS_RET.

    IF LV_FREE GT 0.
      <O>-STOCK = LV_FREE.
    ELSE.
      <O>-STOCK = 0.
    ENDIF.
  ENDLOOP.

ENDFORM.

