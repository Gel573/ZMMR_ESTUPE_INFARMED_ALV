*---------------------------------------------------------------------*
* BUILD_FCAT - Fieldcat LVC (com melhorias de layout)
*---------------------------------------------------------------------*
FORM BUILD_FCAT CHANGING CT_FCAT TYPE LVC_T_FCAT.

  DATA: LT_CFG TYPE STANDARD TABLE OF ZMM_ESTUPE_FCAT,
        LS_CFG TYPE ZMM_ESTUPE_FCAT,
        LS     TYPE LVC_S_FCAT.

  CLEAR CT_FCAT.

  SELECT * FROM ZMM_ESTUPE_FCAT INTO TABLE LT_CFG
  WHERE REPORT EQ 'ZMMR_ESTUPE_INFARMED_ALV'
  ORDER BY COL_POS.

  IF SY-SUBRC = 0 AND LT_CFG IS NOT INITIAL.

    LOOP AT LT_CFG INTO LS_CFG.
      CLEAR LS.

      LS-FIELDNAME  = LS_CFG-FIELDNAME.
      LS-COLTEXT    = LS_CFG-COLTEXT.
      LS-SCRTEXT_M  = LS_CFG-COLTEXT.

      "largura
      IF LS_CFG-OUTPUTLEN IS NOT INITIAL.
        LS-OUTPUTLEN = LS_CFG-OUTPUTLEN.
      ENDIF.

      "invisível
      IF LS_CFG-INVISIVEL = 'X'.
        LS-NO_OUT = ABAP_TRUE.
      ENDIF.

      "alinhamento (ex.: 'L','C','R')
      IF LS_CFG-JUST IS NOT INITIAL.
        LS-JUST = LS_CFG-JUST.
      ENDIF.

      "chave
      IF LS_CFG-ZKEY = 'X'.
        LS-KEY = ABAP_TRUE.
      ENDIF.

      IF LS_CFG-HOTSPOT = 'X'.
        LS-HOTSPOT = ABAP_TRUE.
      ENDIF.

      IF LS_CFG-REF_TABLE IS NOT INITIAL AND LS_CFG-REF_FIELD IS NOT INITIAL.
        LS-REF_TABLE   = LS_CFG-REF_TABLE.
        LS-REF_FIELD   = LS_CFG-REF_FIELD.
      ENDIF.

      APPEND LS TO CT_FCAT.
    ENDLOOP.
    RETURN.
  ENDIF.

  "Fallback (se ainda năo estiver populada)
  PERFORM BUILD_FCAT_FALLBACK CHANGING CT_FCAT.

ENDFORM.


