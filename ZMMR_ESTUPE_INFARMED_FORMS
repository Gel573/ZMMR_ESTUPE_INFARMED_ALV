*---------------------------------------------------------------------*
* GENERATE_PDF_SMARTFORM
* - GETOTF + CONVERT_OTF -> PDF XSTRING
*---------------------------------------------------------------------*
FORM GENERATE_PDF_SMARTFORM USING IT_ITEMS  TYPE ZTTSESTUPE_ITEM
      IS_HEADER TYPE ZSESTUPE_HDR
      IV_DT_INI TYPE D
      IV_DT_TERM TYPE D
CHANGING CV_PDF TYPE XSTRING.

  DATA: LV_FM_NAME  TYPE RS38L_FNAM,
        LS_CTRL     TYPE SSFCTRLOP,
        LS_COMP     TYPE SSFCOMPOP,
        LS_JOBINFO  TYPE SSFCRESCL,
        LT_OTF      TYPE STANDARD TABLE OF ITCOO,
        LT_LINES    TYPE STANDARD TABLE OF TLINE,
        LV_BIN_SIZE TYPE I.

  CLEAR: CV_PDF, LV_FM_NAME, LS_CTRL, LS_COMP, LS_JOBINFO, LT_OTF, LT_LINES, LV_BIN_SIZE.

  "1) Resolver FM do Smartform
  CALL FUNCTION 'SSF_FUNCTION_MODULE_NAME'
    EXPORTING
      FORMNAME           = C_SMARTFORM_NAME
    IMPORTING
      FM_NAME            = LV_FM_NAME
    EXCEPTIONS
      NO_FORM            = 1
      NO_FUNCTION_MODULE = 2
      OTHERS             = 3.

  IF SY-SUBRC <> 0 OR LV_FM_NAME IS INITIAL.
    MESSAGE 'Smartform năo encontrado ou sem FM gerada.' TYPE 'E'.
    RETURN.
  ENDIF.

  "2) Parametrizaçăo para gerar OTF sem diálogo
  CLEAR: LS_CTRL, LS_COMP.
  LS_CTRL-NO_DIALOG = 'X'.
  LS_CTRL-PREVIEW   = SPACE.
  LS_CTRL-GETOTF    = 'X'.
  LS_CTRL-DEVICE    = 'PRINTER'.

  "3) Chamar Smartform gerando OTF
  CALL FUNCTION LV_FM_NAME
    EXPORTING
      CONTROL_PARAMETERS = LS_CTRL
      OUTPUT_OPTIONS     = LS_COMP
      USER_SETTINGS      = SPACE
      IS_HEADER          = IS_HEADER
      IV_DT_INI          = IV_DT_INI
      IV_DT_TERM         = IV_DT_TERM
      IT_ITENS           = IT_ITEMS
    IMPORTING
      JOB_OUTPUT_INFO    = LS_JOBINFO
    EXCEPTIONS
      FORMATTING_ERROR   = 1
      INTERNAL_ERROR     = 2
      SEND_ERROR         = 3
      USER_CANCELED      = 4
      OTHERS             = 5.

  IF SY-SUBRC <> 0 OR LS_JOBINFO-OTFDATA[] IS INITIAL.
    MESSAGE 'Falha ao gerar OTF do Smartform.' TYPE 'E'.
    RETURN.
  ENDIF.

  "4) Converter OTF -> PDF (XSTRING)
  LT_OTF[] = LS_JOBINFO-OTFDATA[].

  CALL FUNCTION 'CONVERT_OTF'
    EXPORTING
      FORMAT                = 'PDF'
    IMPORTING
      BIN_FILE              = CV_PDF
      BIN_FILESIZE          = LV_BIN_SIZE
    TABLES
      OTF                   = LT_OTF
      LINES                 = LT_LINES
    EXCEPTIONS
      ERR_MAX_LINEWIDTH     = 1
      ERR_FORMAT            = 2
      ERR_CONV_NOT_POSSIBLE = 3
      ERR_BAD_OTF           = 4
      OTHERS                = 5.

  IF SY-SUBRC <> 0 OR CV_PDF IS INITIAL.
    CLEAR CV_PDF.
    MESSAGE 'Erro na conversăo OTF->PDF.' TYPE 'E'.
  ENDIF.

ENDFORM.

FORM ALV_REFRESH.

  DATA: LS_STBL  TYPE LVC_S_STBL,
        LT_EMPTY TYPE LVC_T_ROW.

  "Opcional: se o utilizador acabou de gravar MB02/MB1B etc
  WAIT UP TO 1 SECONDS.

  "Recarregar a tabela do report (teu SELECT principal)
  PERFORM GET_DATA.
  "Recalcular stock atual
  PERFORM CALC_STOCK.
  "Refresh no GRID mantendo posiçăo (scroll/coluna)
  IF GO_GRID IS BOUND.

    CLEAR LS_STBL.
    LS_STBL-ROW = 'X'.
    LS_STBL-COL = 'X'.

    CALL METHOD GO_GRID->REFRESH_TABLE_DISPLAY
      EXPORTING
        IS_STABLE      = LS_STBL
        I_SOFT_REFRESH = 'X'
      EXCEPTIONS
        FINISHED       = 1
        OTHERS         = 2.

    "3) Limpar seleçăo após refresh (recomendado)
    CLEAR LT_EMPTY.
    CALL METHOD GO_GRID->SET_SELECTED_ROWS
      EXPORTING
        IT_INDEX_ROWS = LT_EMPTY
      EXCEPTIONS
        OTHERS        = 1.

    "4) Atualizar frontend
    CALL METHOD CL_GUI_CFW=>FLUSH.
  ENDIF.

  "MESSAGE 'Relatório atualizado. Selecione as linhas novamente.' TYPE 'S'.
ENDFORM.

FORM ALV_SELECT_ALL.

  DATA: LT_ROWS TYPE LVC_T_ROW,
        LS_ROW  TYPE LVC_S_ROW,
        LV_IDX  TYPE I.

  IF GO_GRID IS NOT BOUND.
    RETURN.
  ENDIF.

  CLEAR LT_ROWS.

  LV_IDX = 0.
  LOOP AT GT_OUT ASSIGNING FIELD-SYMBOL(<LS_OUT>).
    LV_IDX = LV_IDX + 1.
    CLEAR LS_ROW.
    LS_ROW-INDEX = LV_IDX.
    APPEND LS_ROW TO LT_ROWS.
  ENDLOOP.

  IF LT_ROWS IS INITIAL.
    MESSAGE 'Sem linhas para marcar.' TYPE 'I'.
    RETURN.
  ENDIF.

  CALL METHOD GO_GRID->SET_SELECTED_ROWS
    EXPORTING
      IT_INDEX_ROWS = LT_ROWS
    EXCEPTIONS
      OTHERS        = 1.

  CALL METHOD CL_GUI_CFW=>FLUSH.

ENDFORM.

FORM ALV_DESELECT_ALL.

  DATA LT_EMPTY TYPE LVC_T_ROW.

  IF GO_GRID IS NOT BOUND.
    RETURN.
  ENDIF.

  CLEAR LT_EMPTY.

  CALL METHOD GO_GRID->SET_SELECTED_ROWS
    EXPORTING
      IT_INDEX_ROWS = LT_EMPTY
    EXCEPTIONS
      OTHERS        = 1.

  CALL METHOD CL_GUI_CFW=>FLUSH.

ENDFORM.

FORM FILL_S_MATNR_FROM_SET.

  DATA: LT_VALUES TYPE STANDARD TABLE OF ZST_SET_VALUE,
        LS_VALUE  TYPE ZST_SET_VALUE,
        LS_RNG    LIKE LINE OF S_MATNR,
        LV_LOW    TYPE MATNR18.

  CLEAR S_MATNR[].

  CALL FUNCTION 'ZFM_SET_READ_VALUES'
    EXPORTING
      IV_SETNR  = 'ZMATNR_FARMED2'
      IV_TABLE  = 'ZMM_AUE'
      IV_FIELD  = 'MATNR'
    TABLES
      ET_VALUES = LT_VALUES
    EXCEPTIONS
      OTHERS    = 1.

  IF SY-SUBRC <> 0 OR LT_VALUES IS INITIAL.
    "Opcional: aviso
    "MESSAGE 'SET ZMATNR_FARMED sem valores ou năo encontrado.' TYPE 'W'.
    RETURN.
  ENDIF.

  LOOP AT LT_VALUES INTO LS_VALUE.

    "Só inclusivos
    IF LS_VALUE-SIGN IS NOT INITIAL AND LS_VALUE-SIGN <> 'I'.
      CONTINUE.
    ENDIF.

    "Como o SELECT-OPTION é NO INTERVALS, só aceitamos EQ.
    "Se vier BT/CP/etc, ignoramos (ou podes transformar conforme tua regra)
    IF LS_VALUE-OPTION IS NOT INITIAL AND LS_VALUE-OPTION <> 'EQ'.
      CONTINUE.
    ENDIF.

    CLEAR: LS_RNG, LV_LOW.

    "LOW é CHAR30, converte para MATNR (18) com ALPHA
    LV_LOW = LS_VALUE-LOW.
    CONDENSE LV_LOW NO-GAPS.

    CALL FUNCTION 'CONVERSION_EXIT_ALPHA_INPUT'
      EXPORTING
        INPUT  = LV_LOW
      IMPORTING
        OUTPUT = LV_LOW.

    LS_RNG-SIGN   = 'I'.
    LS_RNG-OPTION = 'EQ'.
    LS_RNG-LOW    = LV_LOW.
    CLEAR LS_RNG-HIGH. "NO INTERVALS

    APPEND LS_RNG TO S_MATNR.

  ENDLOOP.

  "Remover duplicados
  SORT S_MATNR BY LOW.
  DELETE ADJACENT DUPLICATES FROM S_MATNR COMPARING LOW.

ENDFORM.

FORM LOCK_S_MATNR.
  LOOP AT SCREEN.
    "Tudo do select-option S_MATNR (LOW/HIGH, botőes, etc.)
    IF SCREEN-NAME CP 'S_MATNR*'.
      SCREEN-INPUT = 0.
      SCREEN-ACTIVE = 1.
      MODIFY SCREEN.
    ENDIF.
  ENDLOOP.
ENDFORM.

